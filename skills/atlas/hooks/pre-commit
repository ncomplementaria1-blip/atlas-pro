#!/bin/bash
# Enforcement MECÁNICO (2026-06-12 · cierra "gap de enforcement en vivo" del grow-1):
# ningún commit entra al repo de la skill sin atlas-eval PASS. Ni siquiera ATLAS puede saltarlo.
cd "$(git rev-parse --show-toplevel)" || exit 1
python3 eval/atlas-eval.py > /tmp/atlas-eval-precommit.log 2>&1
if [ $? -ne 0 ]; then
  echo "COMMIT BLOQUEADO · atlas-eval FAIL — el motor no acepta regresiones:"
  tail -15 /tmp/atlas-eval-precommit.log
  exit 1
fi
echo "pre-commit · atlas-eval PASS · commit autorizado"
